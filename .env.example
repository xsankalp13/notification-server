# ========================================
# AWS / LocalStack Configuration
# ========================================
AWS_REGION=us-east-1
SQS_ENDPOINT=http://localhost:4566

# SQS Queue URLs (created by the setup-localstack.sh script)
EMAIL_QUEUE=http://localhost:4566/000000000000/email-queue
WHATSAPP_QUEUE=http://localhost:4566/000000000000/whatsapp-queue

# ========================================
# Resend (Email Sending via SMTP)
# ========================================
# Where to get: Go to https://resend.com -> Sign Up -> API Keys -> Create API Key
# The key starts with "re_" (e.g., re_abc123xyz...)
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE

# The "From" email address for outgoing emails.
# Resend provides "onboarding@resend.dev" for free testing (no domain verification needed).
# For production, verify your own domain in Resend and use your custom email.
SENDER_EMAIL=onboarding@resend.dev
